@page
@model SEGEDE_Grupo1.WebApp.Pages.RecoverPasswordModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <p class="text-muted">Ingresa tu correo electrónico y te enviaremos un código para restablecer tu contraseña.</p>
                    <form id="recoverForm">
                        <div class="mb-3">
                            <label class="form-label">Correo Electrónico</label>
                            <input type="email" class="form-control" id="recEmail" required>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Enviar Código de Recuperación</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/LoginViewController.js" asp-append-version="true"></script>
}