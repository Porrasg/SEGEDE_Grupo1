@page
@model SEGEDE_Grupo1.WebApp.Pages.DashboardModel
@{
    ViewData["Title"] = "Centro de Módulos Corporativos";
}

<div class="dashboard-module-container py-2">
    <!-- Encabezado Institucional -->
    <div class="mb-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h2 class="fw-bold tracking-tight mb-1">Módulos Corporativos SGDE</h2>
            <p class="text-muted mb-0 fs-sm">
                Seleccione un módulo operativo para acceder a paneles SCADA, facturación o bitácoras regulatorias.
            </p>
        </div>
        <div>
            <a asp-page="/Index" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2">
                <i class="bi bi-arrow-left"></i>
                <span>Volver a Portal</span>
            </a>
        </div>
    </div>

    <!-- Cuadrícula Modular Responsiva (Smartphone App-Style Grid) -->
    <div class="row g-4" id="moduleCardsGrid">

        <!-- MÓDULO 1: Administración Central eQMS (SuperAdmin, Administrator, Admin) -->
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3" data-roles="superadmin,administrator,admin">
            <a href="/Admin/Dashboard" class="card card-module h-100 text-decoration-none">
                <div class="card-body d-flex flex-column align-items-center text-center p-4">
                    <div class="module-icon-wrapper mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-2 text-heading">Administración General</h5>
                    <p class="card-text text-muted fs-sm mb-4">
                        Gestión de usuarios, auditoría criptográfica, control transaccional del Banco Central y monitoreo integral.
                    </p>
                    <span class="module-action-indicator mt-auto fw-semibold fs-sm d-inline-flex align-items-center gap-1">
                        Abrir Panel <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

        <!-- MÓDULO 2: Control Operativo y SCADA (SuperAdmin, Administrator, Admin, Engineer) -->
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3" data-roles="superadmin,administrator,admin,engineer">
            <a href="/Engineer/Dashboard" class="card card-module h-100 text-decoration-none">
                <div class="card-body d-flex flex-column align-items-center text-center p-4">
                    <div class="module-icon-wrapper mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-cpu-fill"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-2 text-heading">Control Operativo SCADA</h5>
                    <p class="card-text text-muted fs-sm mb-4">
                        Monitoreo en tiempo real de turbinas eólicas, telemetría y estado de carga de baterías locales.
                    </p>
                    <span class="module-action-indicator mt-auto fw-semibold fs-sm d-inline-flex align-items-center gap-1">
                        Acceder <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

        <!-- MÓDULO 3: Portal Comercial y Estados de Cuenta (Buyer, Customer) -->
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3" data-roles="superadmin,administrator,admin,buyer,customer">
            <a href="/Buyer/Dashboard" class="card card-module h-100 text-decoration-none">
                <div class="card-body d-flex flex-column align-items-center text-center p-4">
                    <div class="module-icon-wrapper module-icon-customer mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-file-earmark-bar-graph-fill"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-2 text-heading">Portal del Comprador</h5>
                    <p class="card-text text-muted fs-sm mb-4">
                        Consulta de balances energéticos, liquidaciones mensuales, estados de cuenta y pronósticos.
                    </p>
                    <span class="module-action-indicator mt-auto fw-semibold fs-sm d-inline-flex align-items-center gap-1">
                        Consultar <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

        <!-- MÓDULO 4: Centro de Reportes y Exportación CSV (SuperAdmin, Administrator, Admin, Engineer, Buyer, Customer) -->
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3" data-roles="superadmin,administrator,admin,engineer,buyer,customer">
            <a href="/Admin/Reports" class="card card-module h-100 text-decoration-none">
                <div class="card-body d-flex flex-column align-items-center text-center p-4">
                    <div class="module-icon-wrapper module-icon-reports mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-bar-chart-fill"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-2 text-heading">Centro de Reportes</h5>
                    <p class="card-text text-muted fs-sm mb-4">
                        Generación de informes periódicos, históricos de generación y exportación de datos en CSV y PDF.
                    </p>
                    <span class="module-action-indicator mt-auto fw-semibold fs-sm d-inline-flex align-items-center gap-1">
                        Explorar <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

        <!-- MÓDULO 5: Auditoría Trazable eQMS (SuperAdmin, Administrator, Admin) -->
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3" data-roles="superadmin,administrator,admin">
            <a href="/Admin/Audit" class="card card-module h-100 text-decoration-none">
                <div class="card-body d-flex flex-column align-items-center text-center p-4">
                    <div class="module-icon-wrapper module-icon-audit mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-journal-check"></i>
                    </div>
                    <h5 class="card-title fw-bold mb-2 text-heading">Bitácora de Auditoría</h5>
                    <p class="card-text text-muted fs-sm mb-4">
                        Trazabilidad regulatoria eQMS y registro inmutable de transacciones e incidentes.
                    </p>
                    <span class="module-action-indicator mt-auto fw-semibold fs-sm d-inline-flex align-items-center gap-1">
                        Inspeccionar <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

    </div>
</div>
