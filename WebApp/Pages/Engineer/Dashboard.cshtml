@page
@model SEGEDE_Grupo1.WebApp.Pages.Engineer.DashboardModel
@{
    ViewData["Title"] = "Panel de Operaciones / Ingeniero";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="alert alert-info py-2 mb-3 small">
        <strong>Nota Operativa (RN-030):</strong> Este panel muestra exclusivamente métricas operativas y de generación. La visualización de datos financieros o facturación está restringida.
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center h-100"><div class="card-body"><h6 class="text-muted">Total Turbinas</h6><h3 id="opTotalTurbines">-</h3></div></div>
        </div>
        <div class="col-md-3">
            <div class="card text-center h-100"><div class="card-body"><h6 class="text-muted">Turbinas Activas</h6><h3 id="opActiveTurbines">-</h3></div></div>
        </div>
        <div class="col-md-3">
            <div class="card text-center h-100"><div class="card-body"><h6 class="text-muted">En Mantenimiento</h6><h3 id="opMaintTurbines">-</h3></div></div>
        </div>
        <div class="col-md-3">
            <div class="card text-center h-100"><div class="card-body"><h6 class="text-muted">Turbinas Dañadas</h6><h3 id="opDamagedTurbines">-</h3></div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-center h-100"><div class="card-body"><h6 class="text-muted">Suspendidas por Incumplimiento</h6><h3 id="opSuspendedTurbines">-</h3></div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-center h-100"><div class="card-body"><h6 class="text-muted">Inventario Banco Central</h6><h3 id="opCbInventory">- MWh</h3></div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-center h-100"><div class="card-body"><h6 class="text-muted">Alertas Mantenimiento Vencido</h6><h3 class="text-danger" id="opOverdueAlerts">-</h3></div></div>
        </div>
    </div>
    <div class="card">
        <div class="card-header">Última Operación Flush Completa</div>
        <div class="card-body d-flex justify-content-around text-center">
            <div><h6 class="text-muted">Fecha y Hora</h6><h4 id="opFlushDate">-</h4></div>
            <div><h6 class="text-muted">Energía Trasladada</h6><h4 id="opFlushEnergy">- MWh</h4></div>
        </div>
    </div>
</div>