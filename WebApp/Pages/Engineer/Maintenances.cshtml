@page
@model SEGEDE_Grupo1.WebApp.Pages.Engineer.MaintenancesModel
@{
    ViewData["Title"] = "Programación y Ejecución de Mantenimientos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
    <div class="filter-toolbar">
        <div class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 300px;">
            <select class="form-select form-select-sm" id="engMaintTurbine"><option value="">⚡ Todas las Turbinas</option></select>
        </div>
        <div class="filter-chips-container my-2 my-md-0">
            <button type="button" class="filter-chip active" data-status="" data-target="#engMaintStatus"><i class="bi bi-grid"></i> Todos</button>
            <button type="button" class="filter-chip" data-status="Scheduled" data-target="#engMaintStatus"><i class="bi bi-calendar-event text-info"></i> Programados</button>
            <button type="button" class="filter-chip" data-status="InProgress" data-target="#engMaintStatus"><i class="bi bi-gear-wide-connected text-warning"></i> En Progreso</button>
            <button type="button" class="filter-chip" data-status="Completed" data-target="#engMaintStatus"><i class="bi bi-check-circle-fill text-success"></i> Completados</button>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm d-none" id="engMaintStatus">
                <option value="">Todos los Estados</option>
                <option value="Scheduled">Scheduled</option>
                <option value="InProgress">InProgress</option>
                <option value="Completed">Completed</option>
            </select>
            <button class="btn btn-primary btn-sm px-3 shadow-sm d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#regMaintModal"><i class="bi bi-plus-lg"></i> Programar Mantenimiento</button>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-interactive mb-0 align-middle">
                    <thead class="table-light"><tr><th>ID</th><th>Turbina</th><th>Tipo</th><th>Fechas Estimadas</th><th>Fechas Reales</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
                    <tbody id="engMaintsBody"><tr><td colspan="7" class="text-center py-4 text-muted">Cargando mantenimientos...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- Modal Registrar -->
    <div class="modal fade" id="regMaintModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Programar Mantenimiento</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar diálogo"></button></div><div class="modal-body"><form id="regMaintForm"><div class="mb-2"><label class="form-label">Turbina</label><select class="form-select" id="mTurbine" required></select></div><div class="mb-2"><label class="form-label">Tipo</label><select class="form-select" id="mType"><option value="Preventive">Preventive</option><option value="Corrective">Corrective</option></select></div><div class="row mb-2"><div class="col"><label class="form-label">Inicio Estimado</label><input type="datetime-local" class="form-control" id="mStart" required></div><div class="col"><label class="form-label">Fin Estimado</label><input type="datetime-local" class="form-control" id="mEnd" required></div></div></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-primary" id="saveMaintBtn">Programar</button></div></div></div></div>
    <!-- Modal Completar -->
    <div class="modal fade" id="compMaintModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Completar Mantenimiento</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar diálogo"></button></div><div class="modal-body"><form id="compMaintForm"><div class="mb-3"><label class="form-label">Resultado / Informe Técnico</label><textarea class="form-control" id="mResult" required></textarea></div></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-success" id="confirmCompBtn">Marcar como Completado</button></div></div></div></div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/OperationsComplementaryViewController.js" asp-append-version="true"></script>
}