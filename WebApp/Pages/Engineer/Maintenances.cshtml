@page
@model SEGEDE_Grupo1.WebApp.Pages.Engineer.MaintenancesModel
@{
    ViewData["Title"] = "Programación y Ejecución de Mantenimientos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="d-flex justify-content-between mb-3">
        <div class="d-flex gap-2">
            <select class="form-select" id="engMaintTurbine"><option value="">Todas las Turbinas</option></select>
            <select class="form-select" id="engMaintStatus"><option value="">Todos los Estados</option><option value="Scheduled">Scheduled</option><option value="InProgress">InProgress</option><option value="Completed">Completed</option></select>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#regMaintModal">+ Registrar Mantenimiento</button>
    </div>
    <table class="table table-bordered">
        <thead><tr><th>ID</th><th>Turbina</th><th>Tipo</th><th>Fechas Estimadas</th><th>Fechas Reales</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody id="engMaintsBody"><tr><td colspan="7" class="text-center">Cargando mantenimientos...</td></tr></tbody>
    </table>
    <!-- Modal Registrar -->
    <div class="modal fade" id="regMaintModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Programar Mantenimiento</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><form id="regMaintForm"><div class="mb-2"><label class="form-label">Turbina</label><select class="form-select" id="mTurbine" required></select></div><div class="mb-2"><label class="form-label">Tipo</label><select class="form-select" id="mType"><option value="Preventive">Preventive</option><option value="Corrective">Corrective</option></select></div><div class="row mb-2"><div class="col"><label class="form-label">Inicio Estimado</label><input type="datetime-local" class="form-control" id="mStart" required></div><div class="col"><label class="form-label">Fin Estimado</label><input type="datetime-local" class="form-control" id="mEnd" required></div></div></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-primary" id="saveMaintBtn">Programar</button></div></div></div></div>
    <!-- Modal Completar -->
    <div class="modal fade" id="compMaintModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Completar Mantenimiento</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><form id="compMaintForm"><div class="mb-3"><label class="form-label">Resultado / Informe Técnico</label><textarea class="form-control" id="mResult" required></textarea></div></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-success" id="confirmCompBtn">Marcar como Completado</button></div></div></div></div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/OperationsComplementaryViewController.js" asp-append-version="true"></script>
}