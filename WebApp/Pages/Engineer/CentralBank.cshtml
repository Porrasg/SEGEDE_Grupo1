@page
@model SEGEDE_Grupo1.WebApp.Pages.Engineer.CentralBankModel
@{
    ViewData["Title"] = "Monitoreo del Banco Central";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card text-center p-3 h-100"><h6 class="text-muted">Inventario Actual en Banco Central</h6><h2 class="display-5" id="engCbCurrent">- MWh</h2></div>
        </div>
        <div class="col-md-6">
            <div class="card text-center p-3 h-100"><h6 class="text-muted">Capacidad Efectiva Vigente</h6><h2 class="display-5" id="engCbEffective">- MWh</h2></div>
        </div>
    </div>
    <div class="card">
        <div class="card-header">Movimientos de Inventario (Solo Lectura)</div>
        <div class="card-body p-0"><table class="table table-striped mb-0"><thead><tr><th>ID</th><th>Tipo Movimiento</th><th>Monto (MWh)</th><th>Fecha y Hora</th><th>Descripción</th></tr></thead><tbody id="engCbLogsBody"><tr><td colspan="5" class="text-center">Cargando movimientos...</td></tr></tbody></table></div>
    </div>
</div>