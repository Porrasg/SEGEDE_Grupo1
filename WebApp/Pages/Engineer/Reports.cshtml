@page
@model SEGEDE_Grupo1.WebApp.Pages.Engineer.ReportsModel
@{
    ViewData["Title"] = "Reportes Operativos";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Engineer/Dashboard">Panel Operativo</a></li>
            <li class="breadcrumb-item active" aria-current="page">Reportes</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"] <span class="badge bg-info text-dark ms-2" style="font-size: 0.5em; vertical-align: middle;">Ingeniería</span></h2>
    </div>

    <!-- Reporte 1: Estado actual y alertas de las turbinas -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-activity me-2" aria-hidden="true"></i>Estado Actual y Alertas de Turbinas</span>
            <button class="btn btn-sm btn-outline-primary" id="btnExportStatus" disabled>
                <i class="bi bi-download me-1" aria-hidden="true"></i>Exportar CSV
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead><tr><th scope="col">Código</th><th scope="col">Nombre</th><th scope="col">Ubicación</th><th scope="col">Estado</th><th scope="col">Último Mantenimiento</th><th scope="col">Alertas</th></tr></thead>
                    <tbody id="statusReportBody"><tr><td colspan="6" class="text-center text-muted py-4">Cargando estado de turbinas...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Reporte 2: Historial de mantenimientos por turbina -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-tools me-2" aria-hidden="true"></i>Historial de Mantenimientos por Turbina</span>
            <button class="btn btn-sm btn-outline-primary" id="btnExportMaint" disabled>
                <i class="bi bi-download me-1" aria-hidden="true"></i>Exportar CSV
            </button>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-5">
                    <label class="form-label" for="repMaintTurbineSelect">Turbina</label>
                    <select class="form-select" id="repMaintTurbineSelect"><option value="">Todas las turbinas</option></select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100" id="btnRunMaint">
                        <i class="bi bi-play-fill me-1" aria-hidden="true"></i>Generar Reporte
                    </button>
                </div>
            </div>
            <div class="table-responsive" style="max-height: 420px; overflow-y: auto;">
                <table class="table table-striped table-sm mb-0">
                    <thead><tr><th scope="col">ID</th><th scope="col">Turbina</th><th scope="col">Tipo</th><th scope="col">Inicio Estimado</th><th scope="col">Fin Estimado</th><th scope="col">Fin Real</th><th scope="col">Estado</th><th scope="col">Resultado</th></tr></thead>
                    <tbody id="maintReportBody"><tr><td colspan="8" class="text-center text-muted py-4">Presione "Generar Reporte".</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/ReportsViewController.js" asp-append-version="true"></script>
}
