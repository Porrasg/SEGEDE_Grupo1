@page
@model SEGEDE_Grupo1.WebApp.Pages.RegisterModel
@{
    ViewData["Title"] = "Registro de Comprador";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form id="registerForm">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="regId">Identificación (Cédula/RUC)</label>
                                <input type="text" class="form-control" id="regId" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="regEmail">Correo Electrónico</label>
                                <input type="email" class="form-control" id="regEmail" required>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="regFirstName1"><i class="bi bi-person-fill text-primary"></i> Primer Nombre</label>
                                <input type="text" class="form-control" id="regFirstName1" required placeholder="Ej. Juan">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="regFirstName2"><i class="bi bi-person text-secondary"></i> Segundo Nombre <span class="text-muted small">(Opcional)</span></label>
                                <input type="text" class="form-control" id="regFirstName2" placeholder="Ej. Carlos">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="regLastName1"><i class="bi bi-person-vcard-fill text-primary"></i> Primer Apellido</label>
                                <input type="text" class="form-control" id="regLastName1" required placeholder="Ej. Pérez">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="regLastName2"><i class="bi bi-person-vcard text-primary"></i> Segundo Apellido</label>
                                <input type="text" class="form-control" id="regLastName2" required placeholder="Ej. Rodríguez">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label" for="regPhone">Teléfono</label>
                                <input type="tel" class="form-control" id="regPhone" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="regBirthDate">Fecha de Nacimiento / Constitución</label>
                                <input type="date" class="form-control" id="regBirthDate" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="regAge">Edad <span class="text-muted small">(calculada)</span></label>
                                <input type="text" class="form-control" id="regAge" readonly aria-live="polite" placeholder="—">
                            </div>
                        </div>
                        <div class="row mb-3 align-items-center">
                            <div class="col-md-8">
                                <label class="form-label" for="regPhoto"><i class="bi bi-camera-fill text-primary" aria-hidden="true"></i> Fotografía de Perfil <span class="text-muted small">(Opcional, JPG/PNG)</span></label>
                                <input type="file" class="form-control" id="regPhoto" accept="image/jpeg,image/png,image/webp">
                            </div>
                            <div class="col-md-4 text-center">
                                <img id="regPhotoPreview" src="" alt="Vista previa de la fotografía de perfil seleccionada" class="rounded-circle border d-none" style="width: 84px; height: 84px; object-fit: cover;">
                                <span id="regPhotoPlaceholder" class="d-inline-flex align-items-center justify-content-center rounded-circle border" style="width: 84px; height: 84px;" aria-hidden="true"><i class="bi bi-person fs-2 text-muted"></i></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="regPassword">Contraseña</label>
                                <input type="password" class="form-control" id="regPassword" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="regConfirmPassword">Confirmar Contraseña</label>
                                <input type="password" class="form-control" id="regConfirmPassword" required>
                            </div>
                        </div>
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">Registrar Cuenta</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/LoginViewController.js" asp-append-version="true"></script>
}