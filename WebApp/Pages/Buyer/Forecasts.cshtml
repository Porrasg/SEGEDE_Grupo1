@page
@model SEGEDE_Grupo1.WebApp.Pages.Buyer.ForecastsModel
@{
    ViewData["Title"] = "Mis Pronósticos de Demanda";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="d-flex justify-content-between mb-3">
        <select class="form-select" id="buyForecastYear" style="max-width: 150px;"><option value="2026">2026</option><option value="2027">2027</option></select>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#forecastModal">+ Nuevo Pronóstico</button>
    </div>
    <table class="table table-bordered table-hover">
        <thead><tr><th>Mes</th><th>Año</th><th>Demanda Pronosticada (MWh)</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody id="buyForecastsBody"><tr><td colspan="5" class="text-center">Cargando mis pronósticos...</td></tr></tbody>
    </table>
    <!-- Modal Pronóstico -->
    <div class="modal fade" id="forecastModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Registrar Pronóstico de Demanda</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><form id="forecastForm"><div class="row mb-3"><div class="col"><label class="form-label">Mes</label><select class="form-select" id="fMonth"><option value="1">Enero</option><option value="2">Febrero</option><option value="3">Marzo</option><option value="4">Abril</option><option value="5">Mayo</option><option value="6">Junio</option><option value="7">Julio</option><option value="8">Agosto</option><option value="9">Septiembre</option><option value="10">Octubre</option><option value="11">Noviembre</option><option value="12">Diciembre</option></select></div><div class="col"><label class="form-label">Año</label><input type="number" class="form-control" id="fYear" value="2026" required></div></div><div class="mb-3"><label class="form-label">Demanda Solicitada (MWh)</label><input type="number" step="0.01" class="form-control" id="fAmount" required placeholder="0.00"></div><small class="text-muted">Horizonte permitido: meses futuros hasta un máximo de 12 meses.</small></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-primary" id="saveForecastBtn">Guardar</button></div></div></div></div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/BuyerManagementViewController.js" asp-append-version="true"></script>
}