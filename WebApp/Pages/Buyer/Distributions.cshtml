@page
@model SEGEDE_Grupo1.WebApp.Pages.Buyer.DistributionsModel
@{
    ViewData["Title"] = "Mis Distribuciones de Energía";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="card mb-4">
        <div class="card-body">
            <p class="text-muted mb-0">Consulta el histórico mensual entre la energía que pronosticaste y la energía que te fue asignada durante el ciclo comercial del Banco Central.</p>
        </div>
    </div>
    <table class="table table-bordered">
        <thead><tr><th>Período</th><th>Demanda Solicitada (MWh)</th><th>Energía Asignada (MWh)</th><th>Demanda No Suplida (MWh)</th><th>Escenario</th></tr></thead>
        <tbody id="buyDistBody"><tr><td colspan="5" class="text-center">Cargando mis distribuciones...</td></tr></tbody>
    </table>
</div>