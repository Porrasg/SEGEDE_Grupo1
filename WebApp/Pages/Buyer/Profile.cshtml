@page
@model SEGEDE_Grupo1.WebApp.Pages.Buyer.ProfileModel
@{
    ViewData["Title"] = "Mi Perfil de Comprador";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="row g-4">
        <div class="col-md-5">
            <div class="card h-100">
                <div class="card-header">Información del Comprador</div>
                <div class="card-body text-center">
                    <img src="/images/default-avatar.png" class="rounded-circle mb-3 border" style="width: 100px; height: 100px; object-fit: cover;" alt="Fotografía de perfil del comprador" id="profilePhoto">
                    <h5 id="profName">-</h5>
                    <p class="text-muted mb-1" id="profEmail">-</p>
                    <span class="badge bg-primary mb-3">Comprador</span>
                    <hr>
                    <div class="text-start small">
                        <p><strong>Identificación:</strong> <span id="profId">-</span></p>
                        <p><strong>Fecha Registro:</strong> <span id="profDate">-</span></p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card mb-4">
                <div class="card-header">Actualizar Mis Datos y Seguridad</div>
                <div class="card-body">
                    <form id="profileForm">
                        <div class="mb-3">
                            <label class="form-label" for="pPhone">Teléfono de Contacto</label>
                            <input type="tel" class="form-control" id="pPhone" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="pPhoto">Foto de Perfil <span class="text-muted small">(JPG/PNG)</span></label>
                            <input type="file" class="form-control" id="pPhoto" accept="image/jpeg,image/png,image/webp">
                        </div>
                        <hr>
                        <h6>Cambio de Contraseña (Opcional)</h6>
                        <div class="mb-2"><label class="visually-hidden" for="pCurrPass">Contraseña Actual</label><input type="password" class="form-control" id="pCurrPass" placeholder="Contraseña Actual"></div>
                        <div class="mb-2"><label class="visually-hidden" for="pNewPass">Nueva Contraseña</label><input type="password" class="form-control" id="pNewPass" placeholder="Nueva Contraseña"></div>
                        <button type="submit" class="btn btn-primary mt-2">Guardar Cambios</button>
                    </form>
                </div>
            </div>
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">Zona de Riesgo — Desactivación de Cuenta</div>
                <div class="card-body d-flex justify-content-between align-items-center">
                    <span class="small text-muted">Solicitar la inactivación de mi cuenta de comprador en el sistema SGDE.</span>
                    <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deactModal">Desactivar mi Cuenta</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Modal Desactivación -->
    <div class="modal fade" id="deactModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header bg-danger text-white"><h5 class="modal-title">Confirmar Desactivación</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar diálogo"></button></div><div class="modal-body"><p>¿Estás seguro que deseas desactivar tu cuenta?</p><div class="form-check"><input class="form-check-input" type="checkbox" id="keepForecasts"><label class="form-check-label" for="keepForecasts">Mantener activos mis pronósticos para los próximos 3 meses</label></div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-danger" id="confirmDeactBtn">Confirmar Desactivación</button></div></div></div></div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/BuyerDashboardViewController.js" asp-append-version="true"></script>
}