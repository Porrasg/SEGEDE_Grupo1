@page
@model SEGEDE_Grupo1.WebApp.Pages.Buyer.StatementsModel
@{
    ViewData["Title"] = "Mis Estados de Cuenta";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="d-flex justify-content-between mb-3">
        <select class="form-select" id="buyStmtYear" style="max-width: 150px;"><option value="2026">2026</option></select>
    </div>
    <table class="table table-striped table-hover">
        <thead><tr><th>Período</th><th>Energía Asignada (MWh)</th><th>Subtotal (CRC)</th><th>Impuesto (CRC)</th><th>Total (CRC)</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody id="buyStmtsBody"><tr><td colspan="7" class="text-center">Cargando mis estados de cuenta...</td></tr></tbody>
    </table>
    <!-- Modal Ver Detalle (solo lectura) -->
    <div class="modal fade" id="buyStmtViewModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Detalle del Estado de Cuenta</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <ul class="list-unstyled small mb-0">
                <li class="mb-2 d-flex justify-content-between"><strong>Período:</strong> <span id="vsPeriod">-</span></li>
                <li class="mb-2 d-flex justify-content-between"><strong>Energía Asignada:</strong> <span id="vsAssigned">-</span></li>
                <li class="mb-2 d-flex justify-content-between"><strong>Precio Unitario:</strong> <span id="vsUnitPrice">-</span></li>
                <li class="mb-2 d-flex justify-content-between"><strong>Subtotal:</strong> <span id="vsSubtotal">-</span></li>
                <li class="mb-2 d-flex justify-content-between"><strong>Impuesto:</strong> <span id="vsTax">-</span></li>
                <li class="mb-2 d-flex justify-content-between border-top pt-2"><strong>Total:</strong> <span id="vsTotal" class="fw-bold">-</span></li>
                <li class="mb-2 d-flex justify-content-between"><strong>Estado:</strong> <span id="vsStatus">-</span></li>
                <li class="mb-2 d-flex justify-content-between"><strong>Motivo de Anulación:</strong> <span id="vsAnnulReason">-</span></li>
                <li class="mb-0 d-flex justify-content-between"><strong>Fecha de Emisión:</strong> <span id="vsIssueDate">-</span></li>
            </ul>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button></div>
    </div></div></div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/BuyerManagementViewController.js" asp-append-version="true"></script>
}