@page
@model SEGEDE_Grupo1.WebApp.Pages.Buyer.DashboardModel
@{
    ViewData["Title"] = "Mi Panel de Comprador";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
    <div class="d-flex justify-content-end mb-3">
        <button id="btnSeedDataBuy" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-1">
            <span>⚡ Sembrar Datos Ficticios (Pruebas)</span>
        </button>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center h-100 shadow-sm border-0"><div class="card-body"><h6 class="text-muted">Pronósticos Activos</h6><h3 id="buyActiveForecasts">-</h3></div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-center h-100 shadow-sm border-0"><div class="card-body"><h6 class="text-muted">Demanda Solicitada (Mes Actual)</h6><h3 id="buyMonthReq">- MWh</h3></div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-center h-100 shadow-sm border-0"><div class="card-body"><h6 class="text-muted">Última Asignación Recibida</h6><h3 id="buyLastAssign">- MWh</h3></div></div>
        </div>
        <div class="col-md-6">
            <div class="card text-center h-100 shadow-sm border-0"><div class="card-body"><h6 class="text-muted">Total Facturado Acumulado</h6><h3 id="buyTotalBilled">- CRC</h3></div></div>
        </div>
        <div class="col-md-6">
            <div class="card text-center h-100 shadow-sm border-0"><div class="card-body"><h6 class="text-muted">Fecha Último Estado de Cuenta</h6><h3 id="buyLastStmtDate">-</h3></div></div>
        </div>
    </div>
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0 fw-bold">Demanda Solicitada vs Asignada (Mes Actual)</div>
                <div class="card-body d-flex justify-content-center align-items-center" style="min-height: 280px;">
                    <canvas id="buyDemandChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0 fw-bold">Proporción de Facturación Acumulada</div>
                <div class="card-body d-flex justify-content-center align-items-center" style="min-height: 280px;">
                    <canvas id="buyBillingChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent fw-bold">Acceso Rápido</div>
        <div class="card-body d-flex gap-2">
            <a href="/Buyer/Forecasts" class="btn btn-outline-primary">Gestionar mis Pronósticos</a>
            <a href="/Buyer/Statements" class="btn btn-outline-secondary">Ver mis Estados de Cuenta</a>
            <a href="/Buyer/Distributions" class="btn btn-outline-info">Consultar Distribuciones</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/BuyerDashboardViewController.js" asp-append-version="true"></script>
}