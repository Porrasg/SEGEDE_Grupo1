                <a href="#contacto" class="btn btn-outline-secondary">Contáctenos</a>
            </div>
        </div>
    </div>
    
    <!-- LOGIN INTEGRADO EN LANDING PAGE -->
    <div class="col-lg-5">
        <div class="card border-2 shadow h-100">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-shield-lock me-2"></i>ACCESO AL SISTEMA / LOGIN</h5>
            </div>
            <div class="card-body p-4 d-flex flex-column justify-content-center">
                <p class="text-muted small mb-3">Ingresa tus credenciales para acceder al sistema. Lorem ipsum dolor sit amet consectetur.</p>
                
                <form id="landingLoginForm">
                    <div class="mb-3">
                        <label for="loginIdent" class="form-label fw-bold">Identificación o Correo Electrónico</label>
                        <input type="text" class="form-control" id="loginIdent" required placeholder="ej. usuario@sgde.cr o 101110111">
                    </div>
                    <div class="mb-3">
                        <label for="loginPass" class="form-label fw-bold">Contraseña</label>
                        <input type="password" class="form-control" id="loginPass" required placeholder="••••••••">
                    </div>
                    <div class="d-grid mb-3 mt-4">
                        <button type="submit" class="btn btn-primary py-2 fw-bold">
                            Continuar <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                    <div class="d-flex justify-content-between pt-2 border-top small">
                        <a href="/Register" class="text-dark fw-bold text-decoration-none">¿Nuevo usuario? Regístrate</a>
                        <a href="/RecoverPassword" class="text-muted text-decoration-none">¿Olvidaste tu contraseña?</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

