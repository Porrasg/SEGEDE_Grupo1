<!-- SECCIÓN 4: INFORMACIÓN Y CONTÁCTENOS -->
<div id="contacto" class="mb-4 pt-3">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header">Contacto</div>
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Oficina Principal SGDE</h5>
                    <p class="text-muted small mb-3">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque in ipsum id orci porta dapibus.
                    </p>
                    <hr>
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-2"><strong class="d-inline-block" style="width: 80px;">Ubicación:</strong> San José, Costa Rica</li>
                        <li class="mb-2"><strong class="d-inline-block" style="width: 80px;">Teléfono:</strong> +506 2200-0000</li>
                        <li class="mb-2"><strong class="d-inline-block" style="width: 80px;">Soporte:</strong> info@sgde.cr</li>
                        <li class="mb-0"><strong class="d-inline-block" style="width: 80px;">Horario:</strong> Lunes a Viernes, 8:00 AM - 5:00 PM</li>
                    </ul>
                </div>
            </div>
        </div>
        
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header">Formulario de Contacto</div>
                <div class="card-body">
                    <form id="contactForm">
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Nombre Completo</label>
                                <input type="text" class="form-control" id="cName" required placeholder="Nombre">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" id="cEmail" required placeholder="correo@ejemplo.cr">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Asunto</label>
                            <select class="form-select" id="cSubject">
                                <option value="Consulta">Consulta General</option>
                                <option value="Soporte">Soporte</option>
                                <option value="Otros">Otros</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mensaje</label>
                            <textarea class="form-control" id="cMessage" rows="3" required placeholder="Escriba aquí su mensaje..."></textarea>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-dark px-4">Enviar Mensaje</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Manejo de Login Integrado en Landing Page
            const landingLoginForm = document.getElementById("landingLoginForm");
            if (landingLoginForm) {
                landingLoginForm.addEventListener("submit", function(e) {
                    e.preventDefault();
                    const ident = document.getElementById("loginIdent").value;
                    const pass = document.getElementById("loginPass").value;
                    
                    if (ident && pass) {
                        if (typeof Notifications !== "undefined") {
                            Notifications.showToast("Enviando código OTP de verificación...", "info");
                        }
                        sessionStorage.setItem("temp_login_id", ident);
                        setTimeout(() => {
                            window.location.href = "/LoginOtp";
                        }, 1200);
                    }
                });
            }

            // Manejo de Formulario de Contacto
            const contactForm = document.getElementById("contactForm");
            if (contactForm) {
                contactForm.addEventListener("submit", function(e) {
                    e.preventDefault();
                    if (typeof Notifications !== "undefined") {
                        Notifications.showToast("¡Mensaje enviado con éxito!", "success");
                    }
                    contactForm.reset();
                });
            }
        });
    </script>
}