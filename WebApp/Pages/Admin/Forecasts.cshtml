@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.ForecastsModel
@{
    ViewData["Title"] = "Pronósticos de Demanda";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="d-flex justify-content-between mb-3">
        <div class="d-flex gap-2">
            <select class="form-select" id="filterMonth"><option value="1">Enero</option><option value="2">Febrero</option><option value="3">Marzo</option><option value="4">Abril</option><option value="5">Mayo</option><option value="6">Junio</option><option value="7">Julio</option><option value="8">Agosto</option><option value="9">Septiembre</option><option value="10">Octubre</option><option value="11">Noviembre</option><option value="12">Diciembre</option></select>
            <input type="number" class="form-control" id="filterYear" value="2026" style="width: 120px;">
            <button class="btn btn-secondary" id="btnFilterForecasts">Consultar</button>
        </div>
    </div>
    <table class="table table-bordered">
        <thead><tr><th>Comprador</th><th>Mes / Año</th><th>Demanda Pronosticada (MWh)</th><th>Estado</th><th>Fecha Registro</th></tr></thead>
        <tbody id="forecastsBody"><tr><td colspan="5" class="text-center">Seleccione mes y año para consultar...</td></tr></tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/pages-controller/AdminForecastsViewController.js" asp-append-version="true"></script>
}