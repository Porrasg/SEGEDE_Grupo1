@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.FlushModel
@{
    ViewData["Title"] = "Control y Ejecución de Flush";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a href="/Admin/CentralBank" class="btn btn-outline-secondary btn-sm"><i class="bi bi-bank"></i> Ir a Banco Central</a>
    </div>
        <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="card h-100">
                <div class="card-header">Configuración de Flush Automático</div>
                <div class="card-body">
                    <form id="flushConfigForm">
                        <div class="mb-3">
                            <label class="form-label">Hora de Ejecución (Día 1 de cada mes)</label>
                            <input type="time" class="form-control" id="flushTime" value="00:00">
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="flushAuto" checked>
                            <label class="form-check-label" for="flushAuto">Habilitar Ejecución Automática</label>
                        </div>
                        <button type="submit" class="btn btn-outline-primary">Guardar Configuración</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Estado y Ejecución Manual</span>
                    <span class="badge bg-success" id="flushStatusBadge">Inactivo</span>
                </div>
                <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                    <p class="text-muted">El traslado transaccional ACID vacía el inventario de las baterías locales hacia el Banco Central, aplicando las mermas por saturación.</p>
                    <button class="btn btn-danger btn-lg mt-2" id="btnManualFlush">Ejecutar Flush Manual Ahora</button>
                </div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-header">Historial de Operaciones Flush</div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead><tr><th>ID</th><th>Tipo</th><th>Inicio</th><th>Fin</th><th>Energía Trasladada (MWh)</th><th>Pérdida por Saturación (MWh)</th><th>Estado</th></tr></thead>
                <tbody id="flushHistoryBody"><tr><td colspan="7" class="text-center">Cargando historial...</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/FlushViewController.js" asp-append-version="true"></script>
}