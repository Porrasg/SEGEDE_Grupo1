@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.TaxesModel
@{
    ViewData["Title"] = "Configuración de Impuestos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="card h-100">
                <div class="card-header">Establecer Nuevo Porcentaje de Impuesto</div>
                <div class="card-body">
                    <form id="taxForm">
                        <div class="mb-3">
                            <label class="form-label">Nombre del Impuesto</label>
                            <input type="text" class="form-control" id="taxName" required value="IVA" placeholder="ej. IVA">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Porcentaje de Impuesto (%)</label>
                            <input type="number" step="0.01" class="form-control" id="taxValue" required placeholder="ej. 13.00">
                        </div>
                        <p class="text-muted small">El nuevo impuesto aplica de inmediato; la tasa vigente anterior se cierra automáticamente en ese momento.</p>
                        <button type="submit" class="btn btn-primary">Registrar Impuesto</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header">Historial de Tazas Impositivas</div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead><tr><th>Porcentaje (%)</th><th>Vigente Desde</th><th>Vigente Hasta</th><th>Estado</th></tr></thead>
                        <tbody id="taxesHistoryBody"><tr><td colspan="4" class="text-center">Cargando impuestos...</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/BillingConfigViewController.js" asp-append-version="true"></script>
}