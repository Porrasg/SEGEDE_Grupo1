@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.EnergyStorageModel
@{
    ViewData["Title"] = "Operación y Cortes - Almacenamiento";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="h6">Monitoreo de Baterías Locales</h2>
            <div id="batteriesGrid" class="d-flex flex-wrap gap-3">
                <!-- Cards se insertan por JS -->
            </div>
        </div>

        <div class="col-md-4">
            <h2 class="h6">Estado Banco Central</h2>
            <div class="card p-3 mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <div class="text-muted fs-xs">Inventario Actual</div>
                        <div id="cbInventory" class="fs-4 fw-bold">-- MWh</div>
                    </div>
                    <div>
                        <button id="btnFlush" class="btn btn-danger">Ejecutar Flush Manual</button>
                    </div>
                </div>

                <div class="mt-2">
                    <div class="text-muted fs-xs">Capacidad Máxima</div>
                    <div class="progress" style="height:1.25rem;">
                        <div id="cbProgress" class="progress-bar" role="progressbar" style="width:0%" aria-valuemin="0" aria-valuemax="100">0%</div>
                    </div>
                    <div id="cbCapacityText" class="text-muted fs-xs mt-1">-- / -- MWh</div>
                </div>
            </div>

            <h2 class="h6">Acciones</h2>
            <div class="card p-3">
                <p class="mb-2">Acción manual para vaciar todas las baterías locales hacia el Banco Central.</p>
                <button id="btnFlushSmall" class="btn btn-danger w-100">Realizar Vaciado</button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <h2 class="h6">Historial de Flushes</h2>
            <div class="card p-3">
                <table id="flushHistoryTable" class="table table-striped table-hover w-100">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Transferido (MWh)</th>
                            <th>Pérdida Saturación (MWh)</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const formatDecimal = v => Number(v).toFixed(4);

            async function loadCentralBank() {
                try {
                    const res = await apiClient.get('CentralBank/Inventory');
                    const data = res.Data;
                    $('#cbInventory').text(formatDecimal(data.CurrentInventory) + ' MWh');

                    const effective = (data.ManualCapacity !== null) ? data.ManualCapacity : data.AutomaticCapacity;
                    const percent = effective > 0 ? Math.min(100, (data.CurrentInventory / effective) * 100) : 0;
                    $('#cbProgress').css('width', percent + '%').text(Math.round(percent) + '%');
                    $('#cbCapacityText').text(formatDecimal(data.CurrentInventory) + ' / ' + formatDecimal(effective) + ' MWh');
                } catch (e) {
                    console.error(e);
                }
            }

            async function loadBatteries() {
                try {
                    const turbinesRes = await apiClient.get('Turbines/All');
                    const turbines = turbinesRes.Data || [];
                    $('#batteriesGrid').empty();

                    for (const t of turbines) {
                        try {
                            const bRes = await apiClient.get('Energy/LocalBattery/' + t.Id);
                            const b = bRes.Data;
                            const card = `<div class="card p-3" style="width: 14rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="sgde-avatar rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                                        <i class="bi bi-wind fs-5" aria-hidden="true"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">${t.Name}</div>
                                        <div class="text-muted fs-xs">Turbina #${t.Id}</div>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <div class="text-muted fs-xs">Energía Almacenada</div>
                                    <div class="fs-6 fw-bold">${formatDecimal(b.StoredEnergy)} MWh</div>
                                </div>
                            </div>`;
                            $('#batteriesGrid').append(card);
                        } catch (ex) {
                            console.warn('No battery for turbine', t.Id);
                        }
                    }
                } catch (e) {
                    console.error(e);
                }
            }

            async function loadHistory() {
                try {
                    const res = await apiClient.get('Flush/History?page=1&pageSize=25');
                    const rows = res.Data.Items || [];
                    const tbody = $('#flushHistoryTable tbody').empty();
                    for (const r of rows) {
                        const tr = `<tr>
                            <td>${r.Id}</td>
                            <td>${r.ExecutionType}</td>
                            <td>${r.Status}</td>
                            <td>${new Date(r.StartDate).toLocaleString()}</td>
                            <td>${r.EndDate ? new Date(r.EndDate).toLocaleString() : ''}</td>
                            <td>${Number(r.TotalTransferredEnergy).toFixed(4)}</td>
                            <td>${Number(r.SaturationLoss).toFixed(4)}</td>
                        </tr>`;
                        tbody.append(tr);
                    }
                    $('#flushHistoryTable').DataTable({ destroy: true });
                } catch (e) { console.error(e); }
            }

            async function doFlush() {
                try {
                    const result = await Swal.fire({
                        title: 'Confirmar Vaciado',
                        text: '¿Desea ejecutar un Flush manual ahora? Esta acción vaciará todas las baterías locales.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Sí, Ejecutar',
                        cancelButtonText: 'Cancelar'
                    });
                    if (!result.isConfirmed) return;

                    const callerId = window.session?.getUserId() ?? 1;
                    const r = await apiClient.post('Flush/ExecuteManual?callerUserId=' + encodeURIComponent(callerId));
                    Swal.fire('Flush iniciado', r.Message || 'Flush ejecutado', 'success');
                    await refreshAll();
                } catch (e) {
                    console.error(e);
                    Swal.fire('Error', e.responseJSON?.Message || 'Ocurrió un error al ejecutar el flush', 'error');
                }
            }

            async function refreshAll() {
                await loadCentralBank();
                await loadBatteries();
                await loadHistory();
            }

            $(function () {
                $('#btnFlush').on('click', doFlush);
                $('#btnFlushSmall').on('click', doFlush);
                refreshAll();

                // Polling to show near-real-time values (every 30s to match simulation)
                setInterval(refreshAll, 30000);
            });
        })();
    </script>
}
