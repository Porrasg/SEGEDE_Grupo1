@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.TurbinesModel
@{
    ViewData["Title"] = "Gestión de Turbinas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
    <div class="filter-toolbar">
        <div class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 350px;">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" id="searchTurbine" placeholder="Buscar por código, nombre o ubicación...">
            </div>
        </div>
        <div class="filter-chips-container my-2 my-md-0">
            <button type="button" class="filter-chip active" data-status="" data-target="#filterStatus"><i class="bi bi-grid"></i> Todas</button>
            <button type="button" class="filter-chip" data-status="Active" data-target="#filterStatus"><i class="bi bi-check-circle-fill text-success"></i> Activas</button>
            <button type="button" class="filter-chip" data-status="UnderMaintenance" data-target="#filterStatus"><i class="bi bi-tools text-warning"></i> En Mantenimiento</button>
            <button type="button" class="filter-chip" data-status="Damaged" data-target="#filterStatus"><i class="bi bi-exclamation-triangle-fill text-danger"></i> Dañadas</button>
            <button type="button" class="filter-chip" data-status="SuspendedForNonCompliance" data-target="#filterStatus"><i class="bi bi-pause-circle text-secondary"></i> Suspendidas</button>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm d-none" id="filterStatus">
                <option value="">Todos los Estados</option>
                <option value="Active">Active</option>
                <option value="UnderMaintenance">UnderMaintenance</option>
                <option value="Damaged">Damaged</option>
                <option value="SuspendedForNonCompliance">SuspendedForNonCompliance</option>
            </select>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="btnClearFilters" title="Limpiar todos los filtros"><i class="bi bi-x-circle me-1"></i> Limpiar</button>
            <button class="btn btn-primary btn-sm px-3 shadow-sm d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#turbineModal"><i class="bi bi-plus-lg"></i> Nueva Turbina</button>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-interactive mb-0 align-middle">
                    <thead class="table-light"><tr><th>Código</th><th>Nombre</th><th>Ubicación</th><th>Capacidad (MWh/sem)</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
                    <tbody id="turbinesTableBody"><tr><td colspan="6" class="text-center py-4 text-muted">Cargando turbinas...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- Modal Turbina -->
    <div class="modal fade" id="turbineModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Registrar Turbina</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar diálogo"></button></div><div class="modal-body"><form id="turbineForm"><div class="row mb-2"><div class="col"><label class="form-label">Código Único</label><input type="text" class="form-control" id="tCode" required></div><div class="col"><label class="form-label">Nombre</label><input type="text" class="form-control" id="tName" required></div></div><div class="mb-2"><label class="form-label">Ubicación</label><input type="text" class="form-control" id="tLoc" required></div><div class="row mb-2"><div class="col"><label class="form-label">Marca</label><input type="text" class="form-control" id="tBrand" required></div><div class="col"><label class="form-label">Modelo</label><input type="text" class="form-control" id="tModel" required></div></div><div class="row mb-2"><div class="col"><label class="form-label">Año</label><input type="number" class="form-control" id="tYear" required></div><div class="col"><label class="form-label">Capacidad Nominal (MWh/sem)</label><input type="number" step="0.01" class="form-control" id="tCap" required></div></div></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-primary" id="saveTurbineBtn">Guardar</button></div></div></div></div>
    <!-- Modal Cambio Estado -->
    <div class="modal fade" id="stateModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Cambiar Estado de Turbina</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar diálogo"></button></div><div class="modal-body"><form id="stateForm"><div class="mb-3"><label class="form-label">Nuevo Estado</label><select class="form-select" id="newState"></select></div><div class="mb-3"><label class="form-label">Razón / Justificación</label><textarea class="form-control" id="stateReason" required></textarea></div></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-primary" id="confirmStateBtn">Confirmar Cambio</button></div></div></div></div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/TurbineManagementViewController.js" asp-append-version="true"></script>
}