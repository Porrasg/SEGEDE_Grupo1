@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="d-flex justify-content-between mb-3">
        <div class="d-flex gap-2">
            <input type="text" class="form-control" id="searchUser" placeholder="Buscar por nombre o cédula...">
            <select class="form-select" id="filterRole"><option value="">Todos los Roles</option><option value="Administrator">Administrator</option><option value="Engineer">Engineer</option><option value="Buyer">Buyer</option></select>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#userModal">+ Nuevo Usuario Interno</button>
    </div>
    <table class="table table-striped table-hover">
        <thead><tr><th>Identificación</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody id="usersTableBody"><tr><td colspan="6" class="text-center">Cargando usuarios...</td></tr></tbody>
    </table>
    <!-- Modal -->
    <div class="modal fade" id="userModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Usuario Interno</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><form id="userForm"><div class="mb-2"><label class="form-label">Identificación</label><input type="text" class="form-control" id="uId" required></div><div class="row mb-2"><div class="col"><label class="form-label">Nombre</label><input type="text" class="form-control" id="uFirst" required></div><div class="col"><label class="form-label">Apellidos</label><input type="text" class="form-control" id="uLast" required></div></div><div class="mb-2"><label class="form-label">Correo</label><input type="email" class="form-control" id="uEmail" required></div><div class="mb-2"><label class="form-label">Rol</label><select class="form-select" id="uRole"><option value="Administrator">Administrator</option><option value="Engineer">Engineer</option></select></div><div class="mb-2"><label class="form-label">Contraseña</label><input type="password" class="form-control" id="uPass"></div></form></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-primary" id="saveUserBtn">Guardar</button></div></div></div></div>
</div>