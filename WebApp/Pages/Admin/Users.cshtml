@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2><i class="bi bi-people-fill me-2" style="color: var(--sgde-primary);"></i>@ViewData["Title"]</h2>
            <p class="page-subtitle">Administre los usuarios internos del sistema: ingenieros y administradores.</p>
        </div>
    </div>

    <!-- Filter Toolbar -->
    <div class="filter-toolbar">
        <div class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 350px;">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" id="searchUser" placeholder="Buscar por nombre, correo o cédula...">
            </div>
        </div>
        <div class="filter-chips-container my-2 my-md-0">
            <button type="button" class="filter-chip active" data-status="" data-target="#filterRole"><i class="bi bi-people"></i> Todos</button>
            <button type="button" class="filter-chip" data-status="Administrator" data-target="#filterRole"><i class="bi bi-shield-check text-danger"></i> Administradores</button>
            <button type="button" class="filter-chip" data-status="Engineer" data-target="#filterRole"><i class="bi bi-lightning-charge text-info"></i> Ingenieros</button>
            <button type="button" class="filter-chip" data-status="Buyer" data-target="#filterRole"><i class="bi bi-building text-success"></i> Compradores</button>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm d-none" id="filterRole">
                <option value="">Todos los Roles</option>
                <option value="Administrator">Administrator</option>
                <option value="Engineer">Engineer</option>
                <option value="Buyer">Buyer</option>
            </select>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="btnClearFilters" title="Limpiar filtros"><i class="bi bi-x-circle me-1"></i> Limpiar</button>
            <button class="btn btn-primary btn-sm px-3 shadow-sm d-flex align-items-center gap-1" id="btnOpenNewUser"><i class="bi bi-person-plus-fill"></i> Nuevo Usuario</button>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-interactive mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Identificación</th>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        <tr><td colspan="7" class="text-center py-4 text-muted">Cargando usuarios...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- User Modal (Create / Edit) -->
    <div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="userModalLabel">
                        <i class="bi bi-person-gear me-2"></i>Usuario Interno
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <form id="userForm" novalidate>
                        <!-- Row 1: Identificación + Correo -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="uId">
                                    <i class="bi bi-person-vcard me-1"></i>Identificación
                                </label>
                                <input type="text" class="form-control" id="uId" required placeholder="Ej. 118230456">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="uEmail">
                                    <i class="bi bi-envelope me-1"></i>Correo Electrónico
                                </label>
                                <input type="email" class="form-control" id="uEmail" required placeholder="Ej. usuario@empresa.cr">
                            </div>
                        </div>

                        <!-- Row 2: Nombres -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="uFirst1">Primer Nombre</label>
                                <input type="text" class="form-control" id="uFirst1" required placeholder="Ej. Juan">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="uFirst2">
                                    Segundo Nombre <span class="text-muted small">(Opcional)</span>
                                </label>
                                <input type="text" class="form-control" id="uFirst2" placeholder="Ej. Carlos">
                            </div>
                        </div>

                        <!-- Row 3: Apellidos -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="uLast1">Primer Apellido</label>
                                <input type="text" class="form-control" id="uLast1" required placeholder="Ej. Pérez">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="uLast2">Segundo Apellido</label>
                                <input type="text" class="form-control" id="uLast2" required placeholder="Ej. Rodríguez">
                            </div>
                        </div>

                        <!-- Row 4: Teléfono + Fecha Nacimiento -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="uPhone">
                                    <i class="bi bi-telephone me-1"></i>Teléfono
                                </label>
                                <input type="tel" class="form-control" id="uPhone" required placeholder="Ej. 88881234">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="uBirthDate">
                                    <i class="bi bi-calendar-event me-1"></i>Fecha de Nacimiento
                                </label>
                                <input type="date" class="form-control" id="uBirthDate" required>
                            </div>
                        </div>

                        <!-- Row 5: Rol + Contraseña -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="uRole">
                                    <i class="bi bi-shield me-1"></i>Rol
                                </label>
                                <select class="form-select" id="uRole">
                                    <option value="Administrator">Administrador</option>
                                    <option value="Engineer">Ingeniero</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="uPass">
                                    <i class="bi bi-key me-1"></i>Contraseña
                                    <span class="text-muted small" id="passHint">(requerida)</span>
                                </label>
                                <input type="password" class="form-control" id="uPass" placeholder="Mín. 8 caracteres, may, min, num, especial">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" id="saveUserBtn">
                        <i class="bi bi-check-lg me-1"></i>Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/AdminDashboardViewController.js" asp-append-version="true"></script>
}