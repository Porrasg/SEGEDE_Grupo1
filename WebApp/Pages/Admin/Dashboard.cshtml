@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Turbines" title="Ver flota de turbinas">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Total Turbinas</span>
                    <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-circle"><i class="bi bi-grid-3x3-gap-fill fs-5"></i></span>
                </div>
                <h2 id="kpiTotalTurbines" class="fw-bold mb-0">-</h2>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para gestionar</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Turbines" title="Ver turbinas activas">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Turbinas Activas</span>
                    <span class="badge bg-success bg-opacity-10 text-success p-2 rounded-circle"><i class="bi bi-lightning-charge-fill fs-5"></i></span>
                </div>
                <h2 id="kpiActiveTurbines" class="fw-bold text-success mb-0">-</h2>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para filtrar activas</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/CentralBank" title="Ver Banco Central">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Inventario Banco Central</span>
                    <span class="badge bg-info bg-opacity-10 text-info p-2 rounded-circle"><i class="bi bi-bank fs-5"></i></span>
                </div>
                <h2 id="kpiCbInventory" class="fw-bold mb-0">- <small class="fs-6 text-muted">MWh</small></h2>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para reservas</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Distribution" title="Ver Capacidad">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Capacidad Vigente</span>
                    <span class="badge bg-warning bg-opacity-10 text-warning p-2 rounded-circle"><i class="bi bi-battery-charging fs-5"></i></span>
                </div>
                <h2 id="kpiEffectiveCap" class="fw-bold mb-0">- <small class="fs-6 text-muted">MWh</small></h2>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para distribución</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Forecasts" title="Ver Pronósticos">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Pronósticos del Mes</span>
                    <span class="badge bg-secondary bg-opacity-10 text-secondary p-2 rounded-circle"><i class="bi bi-graph-up-arrow fs-5"></i></span>
                </div>
                <h2 id="kpiMonthForecasts" class="fw-bold mb-0">-</h2>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para pronósticos</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Forecasts" title="Ver Demanda">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Demanda Total Mes</span>
                    <span class="badge bg-danger bg-opacity-10 text-danger p-2 rounded-circle"><i class="bi bi-activity fs-5"></i></span>
                </div>
                <h2 id="kpiTotalDemand" class="fw-bold mb-0">- <small class="fs-6 text-muted">MWh</small></h2>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para demanda</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Statements" title="Ver Estado de Cuentas">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Total Facturado Mes</span>
                    <span class="badge bg-success bg-opacity-10 text-success p-2 rounded-circle"><i class="bi bi-cash-stack fs-5"></i></span>
                </div>
                <h2 id="kpiTotalBilled" class="fw-bold text-success mb-0">- <small class="fs-6 text-muted">CRC</small></h2>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para facturación</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Flush" title="Ver Historial de Flush">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Último Flush</span>
                    <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-circle"><i class="bi bi-water fs-5"></i></span>
                </div>
                <h6 id="kpiLastFlush" class="fw-bold mt-1 mb-0">-</h6>
                <small class="text-muted mt-1 d-block"><i class="bi bi-arrow-right-short"></i> Clic para historial</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 p-3" data-navigate="/Admin/Users" title="Gestionar usuarios">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted fw-semibold" style="font-size: var(--sgde-fs-sm);">Usuarios Activos</span>
                    <span class="badge bg-indigo bg-opacity-10 text-indigo p-2 rounded-circle" style="background-color: rgba(99,102,241,0.1); color: #6366f1;"><i class="bi bi-people-fill fs-5"></i></span>
                </div>
                <h2 id="kpiActiveUsers" class="fw-bold mb-0">-</h2>
                <small class="text-muted mt-1 d-block" id="kpiTotalUsersHint"><i class="bi bi-arrow-right-short"></i> Clic para gestionar</small>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0 fw-bold">Estado Operativo de Flota</div>
                <div class="card-body">
                    <div style="position: relative; height: 280px; width: 100%;">
                        <canvas id="adminTurbineChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0 fw-bold">Demanda Mensual vs Capacidad Banco Central</div>
                <div class="card-body">
                    <div style="position: relative; height: 280px; width: 100%;">
                        <canvas id="adminCapacityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/AdminDashboardViewController.js" asp-append-version="true"></script>
}