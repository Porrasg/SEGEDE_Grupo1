@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.MaintenancesModel
@{
    ViewData["Title"] = "Visión General de Mantenimientos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="d-flex justify-content-between mb-3">
        <div class="d-flex gap-2">
            <select class="form-select" id="maintStatus"><option value="">Todos los Estados</option><option value="Scheduled">Scheduled</option><option value="InProgress">InProgress</option><option value="Completed">Completed</option></select>
            <select class="form-select" id="maintType"><option value="">Todos los Tipos</option><option value="Preventive">Preventive</option><option value="Corrective">Corrective</option></select>
        </div>
    </div>
    <table class="table table-bordered">
        <thead><tr><th>ID</th><th>Turbina</th><th>Tipo</th><th>Inicio Estimado</th><th>Fin Estimado</th><th>Estado</th><th>Resultado</th></tr></thead>
        <tbody id="maintsOverviewBody"><tr><td colspan="7" class="text-center">Cargando mantenimientos...</td></tr></tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/pages-controller/AdminMaintenanceFailureViewController.js" asp-append-version="true"></script>
}