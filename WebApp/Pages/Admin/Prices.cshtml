@page
@model SEGEDE_Grupo1.WebApp.Pages.Admin.PricesModel
@{
    ViewData["Title"] = "Configuración de Precios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
    </div>
        <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="card h-100">
                <div class="card-header">Establecer Nuevo Precio Vigente</div>
                <div class="card-body">
                    <form id="priceForm">
                        <div class="mb-3">
                            <label class="form-label">Precio por MWh (CRC)</label>
                            <input type="number" step="0.01" class="form-control" id="priceValue" required placeholder="ej. 45000.00">
                        </div>
                        <p class="text-muted small">El nuevo precio aplica de inmediato; el precio vigente anterior se cierra automáticamente en ese momento.</p>
                        <button type="submit" class="btn btn-primary">Registrar Precio</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header">Historial de Precios de Energía</div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead><tr><th>Precio (CRC/MWh)</th><th>Vigente Desde</th><th>Vigente Hasta</th><th>Estado</th></tr></thead>
                        <tbody id="pricesHistoryBody"><tr><td colspan="4" class="text-center">Cargando precios...</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages-controller/BillingConfigViewController.js" asp-append-version="true"></script>
}